# Copy to ./{name}/.env and fill in values
# Run 'just new' for an interactive guided setup

# === ORG-SCOPED RUNNER EXAMPLE ===
# RUNNER_SCOPE=org
# ORG_NAME=my-org
# RUNNER_TOKEN=ghp_xxx...              # Personal Access Token (PAT) from GitHub settings
# (REPO_URL is auto-set to https://github.com/{ORG_NAME})

# === REPO-SCOPED RUNNER EXAMPLE ===
# RUNNER_SCOPE=repo
# REPO_URL=https://github.com/user/repo
# RUNNER_TOKEN=xxx...                  # Short-lived token from repo settings > Actions > Runners > New

REPO_URL=                               # (repo scope) https://github.com/user/repo
RUNNER_TOKEN=                           # Access token or runner token (see examples above)
RUNNER_SCOPE=repo                       # org | repo
RUNNER_NAME=                            # Display name for this runner
LABELS=linux,x64                        # Comma-separated labels
RUNNER_WORKDIR=                         # Work directory (leave blank to use /tmp/runner/{RUNNER_NAME})
CPU_LIMIT=1.0                           # CPU cores (e.g. 0.5, 1.0, 2.0)
MEMORY_LIMIT=512m                       # RAM (e.g. 512m, 1g, 2g)
DISABLE_AUTOMATIC_DEREGISTRATION=true   # Keep runner registered on container stop
