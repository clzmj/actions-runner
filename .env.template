# Copy to ./{name}/.env and fill in values
# Run 'just new' for an interactive guided setup

# === ORG-SCOPED RUNNER (Option 1: Runner Token) ===
# RUNNER_SCOPE=org
# ORG_NAME=my-org
# RUNNER_TOKEN=ABCD1234...              # Short-lived, from github.com/organizations/{ORG_NAME}/settings/actions/runners/new
# RUNNER_NAME=my-runner
# LABELS=linux,x64
# RUNNER_WORKDIR=/tmp/runner/my-runner
# CPU_LIMIT=1.0
# MEMORY_LIMIT=512m
# DISABLE_AUTOMATIC_DEREGISTRATION=true

# === ORG-SCOPED RUNNER (Option 2: Access Token / PAT) ===
# RUNNER_SCOPE=org
# ORG_NAME=my-org
# ACCESS_TOKEN=ghp_xxx...               # Personal Access Token (PAT), scope: admin:org
# RUNNER_NAME=my-runner
# LABELS=linux,x64
# RUNNER_WORKDIR=/tmp/runner/my-runner
# CPU_LIMIT=1.0
# MEMORY_LIMIT=512m
# DISABLE_AUTOMATIC_DEREGISTRATION=true

# === REPO-SCOPED RUNNER ===
# RUNNER_SCOPE=repo
# REPO_URL=https://github.com/user/repo
# RUNNER_TOKEN=ABCD1234...              # Short-lived, from {REPO_URL}/settings/actions/runners/new
# RUNNER_NAME=my-runner
# LABELS=linux,x64
# RUNNER_WORKDIR=/tmp/runner/my-runner
# CPU_LIMIT=1.0
# MEMORY_LIMIT=512m
# DISABLE_AUTOMATIC_DEREGISTRATION=true

# Active configuration (uncomment and fill in):
