# Copy to ./{name}/.env and fill in values
REPO_URL=https://github.com/YOUR_ORG_OR_USER/YOUR_REPO
RUNNER_TOKEN=        # Settings > Actions > Runners > New self-hosted runner
RUNNER_SCOPE=org     # org | repo
RUNNER_NAME=
LABELS=linux,x64
RUNNER_WORKDIR=      # leave blank to use /tmp/runner/{name}
CPU_LIMIT=1.0        # cores (e.g. 0.5, 1.0, 2.0)
MEMORY_LIMIT=1g      # e.g. 512m, 1g, 2g
DISABLE_AUTOMATIC_DEREGISTRATION=true
